<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZLauncher.Views.DebugConsoleWindow"
        Title="ZLauncher · Debug"
        Width="860"
        Height="520"
        MinWidth="480"
        MinHeight="280"
        Background="#1A1A1A"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">
        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="#222222"
                BorderBrush="#2E2E2E"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Debug-консоль"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#E0E0E0"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="LineCountText"
                               Text="0 строк"
                               FontSize="11"
                               Foreground="#777777"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="LiveHint"
                               Text="live"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#2ECC71"
                               VerticalAlignment="Center"
                               Opacity="0.85" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Копировать"
                        Classes="DebugToolBtn"
                        Click="OnCopyClick"
                        Margin="0,0,6,0"
                        ToolTip.Tip="Скопировать весь лог" />
                <Button Grid.Column="2"
                        Content="Очистить"
                        Classes="DebugToolBtn"
                        Click="OnClearClick"
                        Margin="0,0,6,0"
                        ToolTip.Tip="Очистить буфер (до следующей установки)" />
                <Button Grid.Column="3"
                        Content="Вниз"
                        Classes="DebugToolBtn"
                        Click="OnScrollBottomClick"
                        ToolTip.Tip="Прокрутить вниз" />
            </Grid>
        </Border>

        <!-- Log body -->
        <Border Grid.Row="1" Background="#141414" Padding="0">
            <ScrollViewer x:Name="LogScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#C8C8C8"
                         CaretBrush="#E67E22"
                         SelectionBrush="#E67E2244"
                         FontFamily="Consolas, Cascadia Mono, Courier New, monospace"
                         FontSize="11.5"
                         Padding="12,10"
                         MinHeight="200" />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Background="#1F1F1F"
                BorderBrush="#2E2E2E"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock Text="3× клик по «ZLauncher» открывает эту консоль. Лог очищается перед каждой новой установкой версии."
                       FontSize="10.5"
                       Foreground="#666666"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.DebugToolBtn">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.DebugToolBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#353535" />
            <Setter Property="BorderBrush" Value="#E67E22" />
        </Style>
        <Style Selector="Button.DebugToolBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1F1F1F" />
        </Style>
    </Window.Styles>
</Window>
