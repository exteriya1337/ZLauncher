<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZLauncher.ViewModels"
        xmlns:models="using:ZLauncher.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="720"
        x:Class="ZLauncher.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/zlauncher.ico"
        Title="ZLauncher"
        Width="1200"
        Height="720"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="Manual"
        Background="Transparent"
        WindowDecorations="None"
        CanResize="False"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="False"
        Win32Properties.WindowCornerPreference="Round">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Window.Styles>
        <!-- Подсвечивается только символ (− / ×), фон кнопки не меняется -->
        <Style Selector="Button.CaptionButton">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#B0B0B0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent" Cursor="Arrow">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}"
                                          Cursor="Arrow">
                            <ContentPresenter.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Foreground" Duration="0:0:0.18" />
                                </Transitions>
                            </ContentPresenter.Transitions>
                        </ContentPresenter>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.CaptionButton:pointerover">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <Style Selector="Button.CaptionButton:pressed">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CF6D16" />
        </Style>

        <!-- Шестерёнка фильтров: своя иконка Path, подсветка как у − / × -->
        <Style Selector="Button.GearButton">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#B0B0B0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent" Cursor="Arrow">
                        <!-- Собственная векторная шестерёнка -->
                        <Path Width="15"
                              Height="15"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Cursor="Arrow"
                              Fill="{TemplateBinding Foreground}"
                              Data="M12,15.5A3.5,3.5 0 0 1 8.5,12A3.5,3.5 0 0 1 12,8.5A3.5,3.5 0 0 1 15.5,12A3.5,3.5 0 0 1 12,15.5M19.43,12.98C19.47,12.66 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11.02L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.65 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.02C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.98Z">
                            <Path.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Fill" Duration="0:0:0.18" />
                                </Transitions>
                            </Path.Transitions>
                        </Path>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.GearButton:pointerover">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <Style Selector="Button.GearButton:pressed">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CF6D16" />
        </Style>

        <!-- Простые чекбоксы фильтров -->
        <Style Selector="CheckBox.FilterCheck">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="CheckBox.FilterCheck:disabled">
            <Setter Property="Foreground" Value="#E67E22" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.FilterRefresh">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#B0B0B0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent" Cursor="Arrow">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                                </Transitions>
                            </ContentPresenter.Transitions>
                        </ContentPresenter>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.FilterRefresh:pointerover">
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <!-- Плавный слайдер RAM: без жёсткого snap, thumb следует за курсором -->
        <Style Selector="Slider.SmoothMemory">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style Selector="Slider.SmoothMemory:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>

        <!-- Карточка мода (Modrinth) -->
        <Style Selector="Button.ModCardButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalContentAlignment="Stretch" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Border.ModCard">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="BorderBrush" Value="#333333" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Width" Value="268" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.18" Easing="CubicEaseOut" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.18" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.ModCard:pointerover">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#2A2620" />
        </Style>

        <!-- Кнопка установки (справа сверху): hover только на #InstallRoot, без Fluent-синего и без ToolTip -->
        <Style Selector="Button.ModInstallBtn">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E67E22" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="ToolTip.Tip" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="InstallRoot"
                            Background="#333333"
                            CornerRadius="6"
                            Cursor="Hand"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.14" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.ModInstallBtn:pointerover /template/ Border#InstallRoot">
            <Setter Property="Background" Value="#3A2E22" />
        </Style>
        <Style Selector="Button.ModInstallBtn:pointerover">
            <Setter Property="Foreground" Value="#F08A30" />
        </Style>
        <Style Selector="Button.ModInstallBtn:pressed /template/ Border#InstallRoot">
            <Setter Property="Background" Value="#2C241C" />
        </Style>
        <Style Selector="Button.ModInstallBtn:pressed">
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>
        <Style Selector="Button.ModInstallBtn:disabled">
            <Setter Property="Opacity" Value="0.7" />
        </Style>

        <Style Selector="TextBox.ModsSearch">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="CaretBrush" Value="#E67E22" />
            <Setter Property="PlaceholderText" Value="Поиск модов на Modrinth…" />
        </Style>
        <Style Selector="TextBox.ModsSearch:pointerover">
            <Setter Property="BorderBrush" Value="#E67E22" />
        </Style>
        <Style Selector="TextBox.ModsSearch:focus">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#2C241C" />
        </Style>

        <!-- Контент вкладок: плавный fade (slide — на TranslateTransform) -->
        <Style Selector="DockPanel.TabPage, Border.TabPage, Panel.TabPage, Grid.TabPage">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.14"
                                      Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Карточки поверх фоновых артов — плотнее, чтобы текст читался -->
        <Style Selector="Grid#TabMods Border.ModCard, Grid#TabResourcePacks Border.ModCard, Grid#TabShaders Border.ModCard">
            <Setter Property="Background" Value="#EE222222" />
            <Setter Property="BorderBrush" Value="#66FFFFFF" />
        </Style>
        <Style Selector="Grid#TabMods Border.ModCard:pointerover, Grid#TabResourcePacks Border.ModCard:pointerover, Grid#TabShaders Border.ModCard:pointerover">
            <Setter Property="Background" Value="#F52A2620" />
            <Setter Property="BorderBrush" Value="#E67E22" />
        </Style>
        <!-- Панель аккаунта на главной — плотнее на фоне -->
        <Style Selector="Border#NickPanel">
            <Setter Property="Background" Value="#F01F1F1F" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
        </Style>

        <!-- Одна новость справа на главной -->
        <Style Selector="Border.NewsCard">
            <Setter Property="Background" Value="#EE222222" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Width" Value="340" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
                    <BrushTransition Property="Background" Duration="0:0:0.16" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.NewsCard:pointerover">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#F02A2620" />
        </Style>
        <Style Selector="Button.NewsCardButton">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalContentAlignment="Stretch" />
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Вкладки основной области -->
        <Style Selector="Button.ContentTab">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="0.8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="TabRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Cursor="Arrow"
                            Padding="{TemplateBinding Padding}">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15" />
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                                </Transitions>
                            </ContentPresenter.Transitions>
                        </ContentPresenter>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.ContentTab:pointerover">
            <Setter Property="Foreground" Value="#C8C8C8" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="Background" Value="#333333" />
        </Style>

        <Style Selector="Button.ContentTab.active">
            <Setter Property="Foreground" Value="#E67E22" />
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#3A2410" />
        </Style>

        <Style Selector="Button.ContentTab.active:pointerover">
            <Setter Property="Foreground" Value="#F08A30" />
            <Setter Property="BorderBrush" Value="#F08A30" />
            <Setter Property="Background" Value="#453018" />
        </Style>

        <!-- Кнопка ИГРАТЬ / УСТАНОВИТЬ (контент — заливка прогресса) -->
        <Style Selector="Button.PlayButton">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="180" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch"
                                      Cursor="Arrow" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.PlayButton:disabled">
            <Setter Property="Opacity" Value="0.45" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>

        <!-- Серый вид заливки, пока кнопка недоступна (загрузка версий и т.п.) -->
        <Style Selector="Button.PlayButton:disabled Border">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>

        <Style Selector="Button.PlayButton:disabled Border Border">
            <Setter Property="Background" Value="#555555" />
        </Style>

        <Style Selector="Button.PlayButton:disabled TextBlock">
            <Setter Property="Foreground" Value="#999999" />
        </Style>

        <!-- Ники -->
        <!-- Без scale: scale вылезает за скруглённые панели и «съедает» края -->
        <Style Selector="Button.NickButton">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="NickBtnRoot"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Cursor="Arrow">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.16" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontSize="14"
                                          TextElement.FontWeight="SemiBold">
                            <ContentPresenter.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Foreground" Duration="0:0:0.16" />
                                </Transitions>
                            </ContentPresenter.Transitions>
                        </ContentPresenter>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.NickButton:pointerover">
            <Setter Property="Background" Value="#444444" />
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <Style Selector="Button.NickButton:pressed">
            <Setter Property="Background" Value="#3A2E22" />
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <!-- Бейджи «Обычный»: жёстко 64px, всегда справа -->
        <Style Selector="Border.TagBadge">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Width" Value="64" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="MaxWidth" Value="64" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        <Style Selector="Border.TagBadge TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="MaxLines" Value="1" />
        </Style>

        <!-- Строки списка ников — на всю ширину dropdown -->
        <Style Selector="ItemsControl.NickList ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <!-- Селект ника (кнопка-заголовок) — исходный размер -->
        <Style Selector="Button.NickSelect">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="SelectRoot"
                            Background="#2A2A2A"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,7"
                            Cursor="Arrow"
                            ClipToBounds="True">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.18" />
                                <BrushTransition Property="Background" Duration="0:0:0.18" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Center"
                                          ClipToBounds="True" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.NickSelect:pointerover /template/ Border#SelectRoot">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#303030" />
        </Style>

        <Style Selector="Button.NickSelect:pressed /template/ Border#SelectRoot">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#2C241C" />
        </Style>

        <!-- Строка списка аккаунтов — hover через /template/ (локальные Styles ItemsControl не перебивают) -->
        <Style Selector="Button.NickListItem">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="ItemRoot"
                            Background="Transparent"
                            Padding="{TemplateBinding Padding}"
                            Margin="0"
                            CornerRadius="6"
                            Cursor="Arrow"
                            ClipToBounds="False"
                            HorizontalAlignment="Stretch">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          ClipToBounds="False" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Прямо на ItemRoot — не зависит от Background кнопки / приоритета Styles -->
        <Style Selector="Button.NickListItem:pointerover /template/ Border#ItemRoot">
            <Setter Property="Background" Value="#333333" />
        </Style>
        <Style Selector="Button.NickListItem:pressed /template/ Border#ItemRoot">
            <Setter Property="Background" Value="#3A2E22" />
        </Style>
        <Style Selector="Button.NickListItem:pointerover TextBlock.NickClipText">
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>
        <Style Selector="Button.NickListItem:pressed TextBlock.NickClipText">
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <Style Selector="TextBox.NickInput">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="CaretBrush" Value="#E67E22" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.18" />
                    <BrushTransition Property="Background" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="TextBox.NickInput:pointerover">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#303030" />
        </Style>

        <Style Selector="TextBox.NickInput:focus">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#2C241C" />
        </Style>

        <!-- Шестерёнка запуска: только цвет, без scale (не обрезает края) -->
        <Style Selector="Button.LaunchGear">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#B0B0B0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="LaunchGearRoot"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Cursor="Arrow"
                            ClipToBounds="True"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.16" />
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
                            </Transitions>
                        </Border.Transitions>
                        <Path Width="18"
                              Height="18"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="{TemplateBinding Foreground}"
                              Data="M12,15.5A3.5,3.5 0 0 1 8.5,12A3.5,3.5 0 0 1 12,8.5A3.5,3.5 0 0 1 15.5,12A3.5,3.5 0 0 1 12,15.5M19.43,12.98C19.47,12.66 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11.02L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.65 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.02C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.98Z">
                            <Path.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Fill" Duration="0:0:0.16" />
                                </Transitions>
                            </Path.Transitions>
                        </Path>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.LaunchGear:pointerover">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <Style Selector="Button.LaunchGear:pointerover /template/ Border#LaunchGearRoot">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#333333" />
        </Style>

        <Style Selector="Button.LaunchGear:pressed /template/ Border#LaunchGearRoot">
            <Setter Property="BorderBrush" Value="#CF6D16" />
            <Setter Property="Background" Value="#2C241C" />
        </Style>

        <!-- Кнопка «папка игры» (рядом с шестерёнкой) -->
        <Style Selector="Button.LaunchFolder">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#B0B0B0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="LaunchFolderRoot"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Cursor="Arrow"
                            ClipToBounds="True"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.16" />
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
                            </Transitions>
                        </Border.Transitions>
                        <!-- Иконка папки -->
                        <Path Width="18"
                              Height="18"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="{TemplateBinding Foreground}"
                              Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z">
                            <Path.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Fill" Duration="0:0:0.16" />
                                </Transitions>
                            </Path.Transitions>
                        </Path>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.LaunchFolder:pointerover">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>
        <Style Selector="Button.LaunchFolder:pointerover /template/ Border#LaunchFolderRoot">
            <Setter Property="BorderBrush" Value="#E67E22" />
            <Setter Property="Background" Value="#333333" />
        </Style>
        <Style Selector="Button.LaunchFolder:pressed /template/ Border#LaunchFolderRoot">
            <Setter Property="BorderBrush" Value="#CF6D16" />
            <Setter Property="Background" Value="#2C241C" />
        </Style>

        <!-- Строка подверсии на вкладке «Версии» -->
        <Style Selector="Button.SubVersionRow">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Cursor="Arrow"
                            ClipToBounds="False">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.14" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Center"
                                          ClipToBounds="False" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.SubVersionRow:pointerover">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style Selector="Button.SubVersionRow.selected">
            <Setter Property="Background" Value="#3A2410" />
        </Style>
        <Style Selector="Button.SubVersionRow.selected:pointerover">
            <Setter Property="Background" Value="#453018" />
        </Style>

        <!-- Список версий (ScrollViewer + ItemsControl — без автоскролла ListBox) -->
        <Style Selector="ScrollViewer.VersionScroll">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <!-- Справа запас под скроллбар; низ — spacer в контенте, padding только лёгкий -->
            <Setter Property="Padding" Value="6,4,10,8" />
            <Setter Property="AllowAutoHide" Value="True" />
        </Style>
        <!-- Список аккаунтов: чистый скролл без padding VersionScroll -->
        <Style Selector="ScrollViewer.NickScroll">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="AllowAutoHide" Value="True" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="ItemsControl.VersionList > ContentPresenter">
            <Setter Property="Margin" Value="0,2" />
        </Style>

        <!-- Панель подверсий: анимация только при Classes.animated -->
        <Style Selector="Border.VariantsPanel.animated">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaxHeight"
                                      Duration="0:0:0.24"
                                      Easing="CubicEaseOut" />
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:0.2"
                                      Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.VariantsPanel:not(.animated)">
            <Setter Property="Transitions">
                <Transitions />
            </Setter>
        </Style>

        <!-- Нижний воздух списка версий — через spacer в XAML (StackPanel), не Margin -->
        <Style Selector="ItemsControl.VersionList">
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="ItemsControl.NickList">
            <!-- Нижний воздух — spacer в StackPanel (как у VersionList), не Margin -->
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ItemsControl.NickList > ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ItemsControl.SubVersionList">
            <Setter Property="Margin" Value="4,4,4,28" />
        </Style>

        <Style Selector="Button.VersionHeader">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="HeaderRoot"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            Cursor="Arrow"
                            ClipToBounds="False">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Center"
                                          ClipToBounds="False" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.VersionHeader:pointerover">
            <Setter Property="Background" Value="#333333" />
        </Style>

        <Style Selector="Button.VersionHeader.selected">
            <Setter Property="Background" Value="#3A2E22" />
        </Style>

        <Style Selector="Button.VersionHeader.selected:pointerover">
            <Setter Property="Background" Value="#4A3A28" />
        </Style>

        <!-- Версия с установленными сборками: чуть ярче имя -->
        <Style Selector="Button.VersionHeader.installed TextBlock.VersionId">
            <Setter Property="Foreground" Value="#E0D0C0" />
        </Style>
        <Style Selector="Button.VersionHeader.selected.installed TextBlock.VersionId">
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <Style Selector="Button.VariantRow">
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="Margin" Value="0,1,2,1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="VariantRoot"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}"
                            Cursor="Arrow"
                            ClipToBounds="False">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Center"
                                          ClipToBounds="False" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.VariantRow:pointerover">
            <Setter Property="Background" Value="#333333" />
        </Style>

        <Style Selector="Button.VariantRow.selected">
            <Setter Property="Background" Value="#3A2E22" />
        </Style>

        <Style Selector="Button.VariantRow.selected:pointerover">
            <Setter Property="Background" Value="#4A3A28" />
        </Style>

        <!-- Оранжевым только имя, не вся строка -->
        <Style Selector="Button.VersionHeader.selected TextBlock.VersionId">
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>

        <Style Selector="Button.VariantRow.selected TextBlock.VariantName">
            <Setter Property="Foreground" Value="#E67E22" />
        </Style>
    </Window.Styles>

    <!-- Внешняя оболочка: тень окна (нужен отступ, иначе тень обрежется) -->
    <Border Margin="14"
            Background="Transparent"
            CornerRadius="10"
            BoxShadow="0 10 28 0 #55000000, 0 2 8 0 #33000000">
    <Border x:Name="RootChrome"
            Background="#2B2B2B"
            CornerRadius="8"
            ClipToBounds="True"
            RenderTransformOrigin="50%,50%">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleX="1" ScaleY="1" />
                <TranslateTransform />
            </TransformGroup>
        </Border.RenderTransform>
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity"
                                  Duration="0:0:0.22"
                                  Easing="CubicEaseOut" />
            </Transitions>
        </Border.Transitions>
        <Grid RowDefinitions="Auto,*">

            <!-- Верхний таб — только за него можно тащить окно -->
            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="#1F1F1F"
                    Height="40"
                    BorderBrush="#171717"
                    BorderThickness="0,0,0,1"
                    PointerPressed="OnTitleBarPointerPressed">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="14,0,8,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="12">
                        <!-- 3× клик открывает Debug-консоль логов установки -->
                        <!-- 3× клик — скрытая Debug-консоль (без подсказки) -->
                        <TextBlock x:Name="BrandTitle"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Cursor="Arrow"
                                   PointerPressed="OnBrandTitlePointerPressed">
                            <Run Text="Z" Foreground="#E67E22" />
                            <Run Text="Launcher" Foreground="#D0D0D0" />
                        </TextBlock>

                        <!-- Тихий статус загрузки рядом с названием -->
                        <TextBlock Text="{Binding DownloadStatusText}"
                                   FontSize="11"
                                   Foreground="#666666"
                                   VerticalAlignment="Center"
                                   Opacity="0.75"
                                   IsVisible="{Binding ShowDownloadStatus}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="420" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="2"
                                Margin="0,-2,0,0">
                        <Button Classes="CaptionButton"
                                Content="−"
                                Click="OnMinimizeClick"
                                ToolTip.Tip="Свернуть" />
                        <Button Classes="CaptionButton"
                                Content="×"
                                Click="OnCloseClick"
                                ToolTip.Tip="Закрыть" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Контент: левый список версий + основная область -->
            <Grid Grid.Row="1" ColumnDefinitions="240,*">

                <!-- Левый таб: версии Minecraft (всегда) -->
                <Border Grid.Column="0"
                        Background="#242424"
                        BorderBrush="#171717"
                        BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- Заголовок + шестерёнка фильтров справа -->
                        <Grid DockPanel.Dock="Top"
                              ColumnDefinitions="*,Auto"
                              Margin="12,10,8,6">
                            <TextBlock Text="ВЕРСИИ"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       LetterSpacing="1"
                                       VerticalAlignment="Center" />

                            <Button x:Name="GearButton"
                                    Grid.Column="1"
                                    Classes="GearButton"
                                    ToolTip.Tip="Фильтры версий"
                                    VerticalAlignment="Center"
                                    Click="OnGearClick" />

                            <!-- Простая панель фильтров -->
                            <Popup x:Name="FilterPopup"
                                   Placement="BottomEdgeAlignedRight"
                                   PlacementTarget="{Binding #GearButton}"
                                   IsLightDismissEnabled="True"
                                   OverlayDismissEventPassThrough="False"
                                   Closed="OnFilterPopupClosed">
                                <Border x:Name="FilterPanel"
                                        Width="200"
                                        Margin="0,6,0,0"
                                        Background="#2A2A2A"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14,12"
                                        Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform Y="-10">
                                            <TranslateTransform.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Y"
                                                                      Duration="0:0:0.2"
                                                                      Easing="CubicEaseOut" />
                                                </Transitions>
                                            </TranslateTransform.Transitions>
                                        </TranslateTransform>
                                    </Border.RenderTransform>
                                    <Border.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Opacity"
                                                              Duration="0:0:0.18"
                                                              Easing="CubicEaseOut" />
                                        </Transitions>
                                    </Border.Transitions>

                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Фильтры"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#AAAAAA"
                                                   Margin="0,0,0,8" />

                                        <!-- Release всегда включён и недоступен для снятия -->
                                        <CheckBox Classes="FilterCheck"
                                                  Content="Релизы"
                                                  IsChecked="True"
                                                  IsEnabled="False"
                                                  ToolTip.Tip="Релизы всегда включены" />
                                        <CheckBox Classes="FilterCheck"
                                                  Content="Снапшоты"
                                                  IsChecked="{Binding ShowSnapshots}" />
                                        <CheckBox Classes="FilterCheck"
                                                  Content="Old Beta"
                                                  IsChecked="{Binding ShowOldBeta}" />
                                        <CheckBox Classes="FilterCheck"
                                                  Content="Old Alpha"
                                                  IsChecked="{Binding ShowOldAlpha}" />

                                        <Border Height="1"
                                                Background="#3A3A3A"
                                                Margin="0,8,0,4" />

                                        <Button Classes="FilterRefresh"
                                                Content="Обновить список"
                                                Command="{Binding ReloadVersionsCommand}" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Индикатор загрузки (плавное исчезновение) -->
                        <StackPanel DockPanel.Dock="Top"
                                    IsVisible="{Binding LoadingBannerVisible}"
                                    Opacity="{Binding LoadingOpacity}"
                                    Margin="16,8,16,8"
                                    Spacing="6">
                            <StackPanel.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity"
                                                      Duration="0:0:0.28"
                                                      Easing="CubicEaseOut" />
                                </Transitions>
                            </StackPanel.Transitions>
                            <TextBlock Text="Загрузка с Mojang…"
                                       FontSize="12"
                                       Foreground="#888888" />
                            <ProgressBar IsIndeterminate="True"
                                         Height="3"
                                         Foreground="#E67E22"
                                         Background="#333333" />
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding ErrorMessage}"
                                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="#E67E22"
                                   Margin="14,4,14,8" />

                        <ScrollViewer x:Name="VersionScroll"
                                      Classes="VersionScroll"
                                      IsEnabled="{Binding !IsLoading}">
                            <!-- StackPanel + spacer: реальный Extent (Margin/overscroll Avalonia часто съедает) -->
                            <StackPanel>
                            <ItemsControl x:Name="VersionList"
                                          Classes="VersionList"
                                          Margin="0"
                                          ItemsSource="{Binding Versions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MinecraftVersionItemViewModel">
                                        <DockPanel x:Name="VersionItemRoot"
                                                   LastChildFill="True"
                                                   ClipToBounds="False"
                                                   Margin="0,2">
                                            <!-- Заголовок версии -->
                                            <Button DockPanel.Dock="Top"
                                                    Classes="VersionHeader"
                                                    Classes.selected="{Binding IsSelected}"
                                                    Classes.installed="{Binding HasInstalledVariant}"
                                                    Command="{Binding ToggleExpandCommand}"
                                                    Focusable="False"
                                                    ClipToBounds="False">
                                                <Grid ColumnDefinitions="16,*,Auto,Auto"
                                                      ClipToBounds="False"
                                                      MinWidth="0">
                                                    <Panel Width="16">
                                                        <!-- Шеврон: плавный поворот 0° → 90° -->
                                                        <TextBlock Text="▸"
                                                                   FontSize="11"
                                                                   Foreground="#B0B0B0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   RenderTransformOrigin="50%,50%">
                                                            <TextBlock.RenderTransform>
                                                                <RotateTransform Angle="{Binding ChevronAngle}">
                                                                    <RotateTransform.Transitions>
                                                                        <Transitions>
                                                                            <DoubleTransition Property="Angle"
                                                                                              Duration="0:0:0.22"
                                                                                              Easing="CubicEaseOut" />
                                                                        </Transitions>
                                                                    </RotateTransform.Transitions>
                                                                </RotateTransform>
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Panel>
                                                    <!-- MinWidth=0 + ClipToBounds: длинный id не вылезает за колонку -->
                                                    <Border Grid.Column="1"
                                                            MinWidth="0"
                                                            ClipToBounds="True"
                                                            Margin="4,0,6,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Classes="VersionId"
                                                                   Text="{Binding DisplayName}"
                                                                   FontSize="13"
                                                                   FontWeight="Medium"
                                                                   Foreground="#D8D8D8"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Stretch"
                                                                   TextAlignment="Left"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   MaxLines="1"
                                                                   MinWidth="0"
                                                                   ClipToBounds="True" />
                                                    </Border>
                                                    <!-- ✓ если есть хотя бы одна установленная подверсия -->
                                                    <TextBlock Grid.Column="2"
                                                               Classes="VersionInstalledMark"
                                                               Text="✓"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="#E67E22"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               IsVisible="{Binding HasInstalledVariant}"
                                                               ClipToBounds="False"
                                                               Margin="6,0,0,0"
                                                               ToolTip.Tip="Есть установленные сборки" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding TypeLabel}"
                                                               FontSize="10"
                                                               Foreground="#666666"
                                                               VerticalAlignment="Center"
                                                               ClipToBounds="False"
                                                               Margin="8,0,0,0" />
                                                </Grid>
                                            </Button>

                                            <!-- Подверсии: MaxHeight + Opacity; transitions выкл. при CollapseInstant -->
                                            <Border Classes="VariantsPanel"
                                                    Classes.animated="{Binding UsePanelAnimation}"
                                                    MaxHeight="{Binding VariantsPanelMaxHeight}"
                                                    Opacity="{Binding PanelOpacity}"
                                                    ClipToBounds="True"
                                                    Margin="0,0,0,2">
                                                <StackPanel Margin="0,0,0,4">
                                                    <Grid ColumnDefinitions="16,*"
                                                          IsVisible="{Binding IsLoadingVariants}"
                                                          MinHeight="32">
                                                        <Border Width="1"
                                                                Background="#555555"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Stretch" />
                                                        <ProgressBar Grid.Column="1"
                                                                     IsIndeterminate="True"
                                                                     Height="2"
                                                                     Margin="4,0,8,0"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="#E67E22"
                                                                     Background="#333333" />
                                                    </Grid>

                                                    <TextBlock Text="{Binding VariantsError}"
                                                               IsVisible="{Binding VariantsError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                               FontSize="10"
                                                               Foreground="#AA7744"
                                                               Margin="20,0,8,4"
                                                               TextWrapping="Wrap" />

                                                    <ItemsControl ItemsSource="{Binding Variants}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:VariantRowViewModel">
                                                                <Grid ColumnDefinitions="16,*" MinHeight="28">
                                                                    <Panel>
                                                                        <Border Width="1"
                                                                                Background="#666666"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Top"
                                                                                Height="14" />
                                                                        <Border Width="1"
                                                                                Background="#666666"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Top"
                                                                                Margin="0,14,0,0"
                                                                                Height="14"
                                                                                IsVisible="{Binding !IsLast}" />
                                                                        <Border Height="1"
                                                                                Width="8"
                                                                                Background="#666666"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Top"
                                                                                Margin="8,13,0,0" />
                                                                    </Panel>

                                                                    <Button Grid.Column="1"
                                                                            Classes="VariantRow"
                                                                            Classes.selected="{Binding IsSelected}"
                                                                            Classes.installed="{Binding IsInstalled}"
                                                                            Focusable="False"
                                                                            Command="{Binding #VersionItemRoot.((vm:MinecraftVersionItemViewModel)DataContext).ChooseVariantCommand}"
                                                                            CommandParameter="{Binding}">
                                                                        <Grid ColumnDefinitions="*,Auto">
                                                                            <TextBlock Classes="VariantName"
                                                                                       Text="{Binding DisplayName}"
                                                                                       FontSize="12"
                                                                                       Foreground="{Binding NameColor}"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       VerticalAlignment="Center"
                                                                                       ClipToBounds="False"
                                                                                       Margin="0,0,6,0" />
                                                                            <TextBlock Grid.Column="1"
                                                                                       Classes="VariantKind"
                                                                                       Text="{Binding KindLabel}"
                                                                                       FontSize="10"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{Binding KindColor}"
                                                                                       Margin="8,0,0,0"
                                                                                       VerticalAlignment="Center"
                                                                                       ClipToBounds="False" />
                                                                        </Grid>
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Воздух под последней плашкой — иначе низ режется viewport/скруглением -->
                            <Border Height="48"
                                    Background="Transparent"
                                    IsHitTestVisible="False" />
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Основная область: фоны edge-to-edge + вкладки поверх -->
                <Grid Grid.Column="1"
                      Background="#1A1A1A"
                      ClipToBounds="True"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

                    <!-- Контент вкладок на ВСЮ колонку (под табы, до краёв) -->
                    <Panel Margin="0"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           ClipToBounds="True">

                    <!-- ── Фон «Главная» ── -->
                    <Grid x:Name="TabHome"
                          Classes="TabPage"
                          Opacity="0"
                          IsHitTestVisible="False"
                          ClipToBounds="True"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Margin="0">
                        <Border HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <ImageBrush Source="avares://ZLauncher/Assets/home-bg.jpg"
                                            Stretch="UniformToFill"
                                            AlignmentX="Center"
                                            AlignmentY="Center" />
                            </Border.Background>
                        </Border>
                        <Border Background="#66222222" IsHitTestVisible="False" />
                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <RadialGradientBrush Center="50%,48%"
                                                     GradientOrigin="50%,48%"
                                                     RadiusX="1.05"
                                                     RadiusY="1.0">
                                    <GradientStop Offset="0" Color="#00000000" />
                                    <GradientStop Offset="0.65" Color="#22000000" />
                                    <GradientStop Offset="1" Color="#AA121212" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Кнопка на сайт (слева сверху) -->
                        <Button HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="20,56,0,0"
                                Classes="ContentTab"
                                Content="САЙТ"
                                Command="{Binding OpenWebsiteCommand}"
                                ToolTip.Tip="Открыть сайт ZLauncher"
                                ZIndex="1" />

                        <!-- Новость справа (над кнопкой «Установить») -->
                        <StackPanel HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,56,24,100"
                                    Width="340"
                                    Spacing="8"
                                    ZIndex="1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="НОВОСТЬ"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#CCCCCC"
                                               LetterSpacing="1" />
                                    <TextBlock Text="{Binding NewsStatusText}"
                                               FontSize="11"
                                               Foreground="#999999"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="ContentTab"
                                        Content="ОБНОВИТЬ"
                                        Command="{Binding RefreshNewsCommand}"
                                        IsEnabled="{Binding !IsLoadingNews}"
                                        ToolTip.Tip="Обновить новость Mojang"
                                        VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="{Binding NewsError}"
                                       IsVisible="{Binding NewsError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       FontSize="12"
                                       Foreground="#E67E22"
                                       TextWrapping="Wrap" />

                            <StackPanel Spacing="8"
                                        HorizontalAlignment="Center"
                                        Margin="0,24,0,0"
                                        IsVisible="{Binding IsLoadingNews}">
                                <ProgressBar IsIndeterminate="True"
                                             Width="140"
                                             Height="3"
                                             Foreground="#E67E22"
                                             Background="#333333" />
                                <TextBlock Text="Загрузка…"
                                           FontSize="12"
                                           Foreground="#AAAAAA"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding NewsCards}"
                                          IsVisible="{Binding !IsLoadingNews}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NewsCardViewModel">
                                        <Border Classes="NewsCard">
                                            <Button Classes="NewsCardButton"
                                                    Command="{Binding OpenArticleCommand}"
                                                    ToolTip.Tip="Открыть на minecraft.net">
                                                <StackPanel>
                                                    <Border Height="130"
                                                            Background="#1A1A1A"
                                                            ClipToBounds="True">
                                                        <Panel>
                                                            <TextBlock Text="MC"
                                                                       FontSize="20"
                                                                       FontWeight="Bold"
                                                                       Foreground="#444444"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       IsVisible="{Binding !HasImage}" />
                                                            <Image Source="{Binding Image}"
                                                                   Stretch="UniformToFill"
                                                                   HorizontalAlignment="Stretch"
                                                                   VerticalAlignment="Stretch"
                                                                   IsVisible="{Binding HasImage}" />
                                                        </Panel>
                                                    </Border>
                                                    <StackPanel Margin="12,10,12,12" Spacing="6">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <Border Background="#333333"
                                                                    CornerRadius="4"
                                                                    Padding="6,2">
                                                                <TextBlock Text="{Binding TagLabel}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#E67E22" />
                                                            </Border>
                                                            <TextBlock Text="{Binding DateLabel}"
                                                                       FontSize="10"
                                                                       Foreground="#888888"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding TitleRu}"
                                                                   Opacity="{Binding TitleOpacity}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#E8E8E8"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxLines="2">
                                                            <TextBlock.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="Opacity"
                                                                                      Duration="0:0:0.16"
                                                                                      Easing="CubicEaseOut" />
                                                                </Transitions>
                                                            </TextBlock.Transitions>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding TextRu}"
                                                                   Opacity="{Binding TextOpacity}"
                                                                   FontSize="11"
                                                                   LineHeight="16"
                                                                   Foreground="#B8B8B8"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxLines="3">
                                                            <TextBlock.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="Opacity"
                                                                                      Duration="0:0:0.16"
                                                                                      Easing="CubicEaseOut" />
                                                                </Transitions>
                                                            </TextBlock.Transitions>
                                                        </TextBlock>
                                                        <TextBlock Text="Читать →"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#E67E22"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <!-- ── Вкладка «Версии»: все подверсии выбранной MC-версии ── -->
                    <Grid x:Name="TabVersions"
                          Classes="TabPage"
                          Opacity="0"
                          IsHitTestVisible="False"
                          ClipToBounds="True"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <Grid.RenderTransform>
                            <TranslateTransform Y="12" />
                        </Grid.RenderTransform>

                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <ImageBrush Source="avares://ZLauncher/Assets/versions-bg.jpg"
                                            Stretch="UniformToFill"
                                            AlignmentX="Center"
                                            AlignmentY="Center" />
                            </Border.Background>
                        </Border>
                        <Border Background="#66222222" IsHitTestVisible="False" />
                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <RadialGradientBrush Center="50%,45%"
                                                     GradientOrigin="50%,45%"
                                                     RadiusX="1.05"
                                                     RadiusY="1.0">
                                    <GradientStop Offset="0" Color="#00000000" />
                                    <GradientStop Offset="0.65" Color="#22000000" />
                                    <GradientStop Offset="1" Color="#AA121212" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>

                        <DockPanel Margin="28,56,28,24">
                        <Grid DockPanel.Dock="Top"
                              ColumnDefinitions="*,Auto"
                              Margin="0,0,0,12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="ПОДВЕРСИИ"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#CCCCCC"
                                           LetterSpacing="1" />
                                <TextBlock Text="{Binding SelectedVersion.DisplayName, TargetNullValue=Версия не выбрана}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#E8E8E8" />
                                <TextBlock Text="{Binding SelectedBuildSummary}"
                                           FontSize="12"
                                           Foreground="#E67E22"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="ContentTab"
                                    Content="НА ГЛАВНУЮ"
                                    VerticalAlignment="Top"
                                    Command="{Binding ConfirmVersionAndGoHomeCommand}"
                                    ToolTip.Tip="Вернуться на главную" />
                        </Grid>

                        <Border Background="#EE1F1F1F"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,6"
                                ClipToBounds="True">
                            <Panel>
                                <!-- Нет выбранной версии -->
                                <TextBlock Text="Выберите версию Minecraft в списке слева."
                                           FontSize="13"
                                           Foreground="#777777"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding SelectedVersion, Converter={x:Static ObjectConverters.IsNull}}" />

                                <!-- Первая загрузка (ещё нет seed) -->
                                <StackPanel Spacing="10"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsLoadingFullVariants}">
                                    <ProgressBar IsIndeterminate="True"
                                                 Width="160"
                                                 Height="3"
                                                 Foreground="#E67E22"
                                                 Background="#333333" />
                                    <TextBlock Text="Загрузка сборок…"
                                               FontSize="12"
                                               Foreground="#888888"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="{Binding FullVariantsError}"
                                           FontSize="12"
                                           Foreground="#E8A060"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="16,12"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding FullVariantsError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                <!-- Список: seed сразу, полный — пакетами в фоне -->
                                <DockPanel IsVisible="{Binding !IsLoadingFullVariants}">
                                    <StackPanel DockPanel.Dock="Top"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                Margin="8,4,8,6"
                                                IsVisible="{Binding IsRefreshingFullVariants}">
                                        <ProgressBar IsIndeterminate="True"
                                                     Width="80"
                                                     Height="2"
                                                     VerticalAlignment="Center"
                                                     Foreground="#E67E22"
                                                     Background="#333333" />
                                        <TextBlock Text="Догружаем все сборки…"
                                                   FontSize="11"
                                                   Foreground="#777777"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <ScrollViewer x:Name="SubVersionScroll"
                                                  Classes="VersionScroll"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl Classes="SubVersionList"
                                                      ItemsSource="{Binding FullVariants}"
                                                      Margin="4,4,4,28">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:VariantRowViewModel">
                                                    <Button Classes="SubVersionRow"
                                                            Classes.selected="{Binding IsSelected}"
                                                            Classes.installed="{Binding IsInstalled}"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch"
                                                            Focusable="False"
                                                            Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ChooseSubVersionCommand}"
                                                            CommandParameter="{Binding}"
                                                            Margin="0,2">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="12,10">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{Binding NameColor}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center"
                                                                       ClipToBounds="False"
                                                                       Margin="0,0,8,0" />
                                                            <Border Grid.Column="1"
                                                                    Classes="TagBadge"
                                                                    Background="#2A2A2A"
                                                                    Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding KindLabel}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding KindColor}"
                                                                           ClipToBounds="False" />
                                                            </Border>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="✓"
                                                                       FontSize="14"
                                                                       FontWeight="Bold"
                                                                       Foreground="#E67E22"
                                                                       Margin="10,0,4,0"
                                                                       VerticalAlignment="Center"
                                                                       IsVisible="{Binding IsInstalled}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Panel>
                        </Border>
                        </DockPanel>
                    </Grid>

                    <!-- ── Вкладка «Модификации» (Modrinth) ── -->
                    <Grid x:Name="TabMods"
                          Classes="TabPage"
                          Opacity="0"
                          IsHitTestVisible="False"
                          ClipToBounds="True"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <Grid.RenderTransform>
                            <TranslateTransform Y="12" />
                        </Grid.RenderTransform>

                        <!-- Фон: Mounts of Mayhem + затемнение -->
                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <ImageBrush Source="avares://ZLauncher/Assets/mods-bg.jpg"
                                            Stretch="UniformToFill"
                                            AlignmentX="Center"
                                            AlignmentY="Center" />
                            </Border.Background>
                        </Border>
                        <Border Background="#66222222" IsHitTestVisible="False" />
                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <RadialGradientBrush Center="50%,45%"
                                                     GradientOrigin="50%,45%"
                                                     RadiusX="1.05"
                                                     RadiusY="1.0">
                                    <GradientStop Offset="0" Color="#00000000" />
                                    <GradientStop Offset="0.65" Color="#22000000" />
                                    <GradientStop Offset="1" Color="#AA121212" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>

                        <DockPanel Margin="20,56,16,16">
                        <!-- Поиск + фильтр -->
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,8,10">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0">
                                <CheckBox IsChecked="{Binding ModsFilterBySelectedVersion}"
                                          Content="Только для выбранной версии"
                                          FontSize="11"
                                          Foreground="#DDDDDD"
                                          VerticalAlignment="Center"
                                          ToolTip.Tip="Фильтр по версии Minecraft из списка слева" />
                                <Button Classes="ContentTab"
                                        Content="НАЙТИ"
                                        Command="{Binding SearchModsCommand}"
                                        MinWidth="72"
                                        ToolTip.Tip="Искать на Modrinth" />
                            </StackPanel>
                            <TextBox Classes="ModsSearch"
                                     Text="{Binding ModsSearchQuery}"
                                     VerticalAlignment="Center">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding SearchModsCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                        </DockPanel>

                        <!-- Фильтр: Все / Установленные / Не установленные -->
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    Margin="0,0,8,10">
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsModsFilterAll}"
                                    Content="ВСЕ"
                                    Command="{Binding SetModsInstallFilterCommand}"
                                    CommandParameter="all"
                                    MinWidth="64"
                                    ToolTip.Tip="Показать все моды из поиска" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsModsFilterInstalled}"
                                    Content="УСТАНОВЛЕННЫЕ"
                                    Command="{Binding SetModsInstallFilterCommand}"
                                    CommandParameter="installed"
                                    MinWidth="110"
                                    ToolTip.Tip="Только моды из папки mods" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsModsFilterNotInstalled}"
                                    Content="НЕ УСТАНОВЛЕННЫЕ"
                                    Command="{Binding SetModsInstallFilterCommand}"
                                    CommandParameter="not_installed"
                                    MinWidth="130"
                                    ToolTip.Tip="Моды из поиска, которых ещё нет в mods" />
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding ModsStatusText}"
                                   FontSize="11"
                                   Foreground="#777777"
                                   Margin="2,0,8,8"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding ModsError}"
                                   IsVisible="{Binding ModsError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontSize="12"
                                   Foreground="#E67E22"
                                   TextWrapping="Wrap"
                                   Margin="2,0,8,8" />

                        <!-- Загрузка -->
                        <StackPanel DockPanel.Dock="Top"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    Margin="0,40,0,0"
                                    IsVisible="{Binding IsLoadingMods}">
                            <ProgressBar IsIndeterminate="True"
                                         Width="160"
                                         Height="3"
                                         Foreground="#E67E22"
                                         Background="#333333" />
                            <TextBlock Text="Загрузка модов с Modrinth…"
                                       FontSize="12"
                                       Foreground="#888888"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <ScrollViewer x:Name="ModsScroll"
                                      Classes="VersionScroll"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding !IsLoadingMods}">
                            <!-- Кнопка «Ещё моды» только в конце списка (после долистывания) -->
                            <StackPanel Margin="0,0,4,20">
                                <ItemsControl ItemsSource="{Binding VisibleModCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModCardViewModel">
                                            <Border Classes="ModCard">
                                                <Grid>
                                                    <!-- Клик по карточке → страница на Modrinth -->
                                                    <Button Classes="ModCardButton"
                                                            Command="{Binding OpenOnModrinthCommand}"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            ToolTip.Tip="Открыть на Modrinth">
                                                        <StackPanel Spacing="8" Margin="0,0,28,0">
                                                            <Grid ColumnDefinitions="48,*">
                                                                <Border Width="48"
                                                                        Height="48"
                                                                        CornerRadius="8"
                                                                        Background="#1A1A1A"
                                                                        ClipToBounds="True"
                                                                        VerticalAlignment="Top">
                                                                    <Panel>
                                                                        <TextBlock Text="{Binding TypeGlyph}"
                                                                                   FontSize="18"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#555555"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   IsVisible="{Binding !HasIcon}" />
                                                                        <Image Source="{Binding Icon}"
                                                                               Width="48"
                                                                               Height="48"
                                                                               Stretch="UniformToFill"
                                                                               IsVisible="{Binding HasIcon}" />
                                                                    </Panel>
                                                                </Border>
                                                                <StackPanel Grid.Column="1"
                                                                            Margin="10,0,0,0"
                                                                            Spacing="2">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#E8E8E8"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="1" />
                                                                    <TextBlock Text="{Binding Author}"
                                                                               FontSize="11"
                                                                               Foreground="#888888"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock Text="{Binding DownloadsLabel}"
                                                                                   FontSize="10"
                                                                                   Foreground="#E67E22"
                                                                                   VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding GameVersionHint}"
                                                                                   FontSize="10"
                                                                                   Foreground="#666666"
                                                                                   VerticalAlignment="Center"
                                                                                   IsVisible="{Binding GameVersionHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Grid>
                                                            <TextBlock Text="{Binding DescriptionRu}"
                                                                       Opacity="{Binding DescriptionOpacity}"
                                                                       FontSize="11"
                                                                       LineHeight="16"
                                                                       Foreground="#A8A8A8"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="3"
                                                                       MinHeight="48">
                                                                <TextBlock.Transitions>
                                                                    <Transitions>
                                                                        <DoubleTransition Property="Opacity"
                                                                                          Duration="0:0:0.16"
                                                                                          Easing="CubicEaseOut" />
                                                                    </Transitions>
                                                                </TextBlock.Transitions>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding CategoriesText}"
                                                                       FontSize="10"
                                                                       Foreground="#555555"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       IsVisible="{Binding CategoriesText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                            <TextBlock Text="{Binding InstallStatus}"
                                                                       FontSize="10"
                                                                       Foreground="#E67E22"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       IsVisible="{Binding InstallStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                        </StackPanel>
                                                    </Button>

                                                    <!-- Установка — справа сверху (без ToolTip: не всплывает поверх карточки) -->
                                                    <Button Classes="ModInstallBtn"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="0,-2,-2,0"
                                                            ZIndex="2"
                                                            Content="{Binding InstallIconGlyph}"
                                                            Command="{Binding InstallModCommand}"
                                                            IsEnabled="{Binding CanInstall}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- В самом низу ленты — видно только после долистывания -->
                                <Button Classes="ContentTab"
                                        Content="Ещё моды"
                                        HorizontalAlignment="Center"
                                        Margin="0,12,0,8"
                                        Command="{Binding LoadMoreModsCommand}"
                                        IsVisible="{Binding CanLoadMoreMods}"
                                        IsEnabled="{Binding !IsLoadingMoreMods}"
                                        ToolTip.Tip="Загрузить следующую страницу с Modrinth" />

                                <StackPanel Spacing="6"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,4"
                                            IsVisible="{Binding IsLoadingMoreMods}">
                                    <ProgressBar IsIndeterminate="True"
                                                 Width="120"
                                                 Height="2"
                                                 Foreground="#E67E22"
                                                 Background="#333333" />
                                    <TextBlock Text="Загрузка…"
                                               FontSize="11"
                                               Foreground="#777777"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        </DockPanel>
                    </Grid>

                    <!-- ── Вкладка «Ресурспаки» (Modrinth resourcepack) ── -->
                    <Grid x:Name="TabResourcePacks"
                          Classes="TabPage"
                          Opacity="0"
                          IsHitTestVisible="False"
                          ClipToBounds="True"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <Grid.RenderTransform>
                            <TranslateTransform Y="12" />
                        </Grid.RenderTransform>

                        <!-- 1) Арт на весь фон (avares — надёжная загрузка из сборки) -->
                        <Border HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <ImageBrush Source="avares://ZLauncher/Assets/rp-bg.jpg"
                                            Stretch="UniformToFill"
                                            AlignmentX="Center"
                                            AlignmentY="Center" />
                            </Border.Background>
                        </Border>

                        <Border Background="#66222222" IsHitTestVisible="False" />
                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <RadialGradientBrush Center="50%,45%"
                                                     GradientOrigin="50%,45%"
                                                     RadiusX="1.05"
                                                     RadiusY="1.0">
                                    <GradientStop Offset="0" Color="#00000000" />
                                    <GradientStop Offset="0.65" Color="#22000000" />
                                    <GradientStop Offset="1" Color="#AA121212" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Контент вкладки -->
                        <DockPanel Margin="20,56,16,16">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,8,10">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0">
                                <CheckBox IsChecked="{Binding RpFilterBySelectedVersion}"
                                          Content="Только для выбранной версии"
                                          FontSize="11"
                                          Foreground="#DDDDDD"
                                          VerticalAlignment="Center"
                                          ToolTip.Tip="Фильтр по версии Minecraft из списка слева" />
                                <Button Classes="ContentTab"
                                        Content="НАЙТИ"
                                        Command="{Binding SearchResourcePacksCommand}"
                                        MinWidth="72"
                                        ToolTip.Tip="Искать ресурспаки на Modrinth" />
                            </StackPanel>
                            <TextBox Classes="ModsSearch"
                                     Text="{Binding RpSearchQuery}"
                                     PlaceholderText="Поиск ресурспаков…"
                                     VerticalAlignment="Center">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding SearchResourcePacksCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                        </DockPanel>

                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    Margin="0,0,8,10">
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsRpFilterAll}"
                                    Content="ВСЕ"
                                    Command="{Binding SetRpInstallFilterCommand}"
                                    CommandParameter="all"
                                    MinWidth="64"
                                    ToolTip.Tip="Показать все ресурспаки из поиска" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsRpFilterInstalled}"
                                    Content="УСТАНОВЛЕННЫЕ"
                                    Command="{Binding SetRpInstallFilterCommand}"
                                    CommandParameter="installed"
                                    MinWidth="110"
                                    ToolTip.Tip="Только из папки resourcepacks" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsRpFilterNotInstalled}"
                                    Content="НЕ УСТАНОВЛЕННЫЕ"
                                    Command="{Binding SetRpInstallFilterCommand}"
                                    CommandParameter="not_installed"
                                    MinWidth="130"
                                    ToolTip.Tip="Из поиска, которых ещё нет в resourcepacks" />
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding RpStatusText}"
                                   FontSize="11"
                                   Foreground="#777777"
                                   Margin="2,0,8,8"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding RpError}"
                                   IsVisible="{Binding RpError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontSize="12"
                                   Foreground="#E67E22"
                                   TextWrapping="Wrap"
                                   Margin="2,0,8,8" />

                        <StackPanel DockPanel.Dock="Top"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    Margin="0,40,0,0"
                                    IsVisible="{Binding IsLoadingResourcePacks}">
                            <ProgressBar IsIndeterminate="True"
                                         Width="160"
                                         Height="3"
                                         Foreground="#E67E22"
                                         Background="#333333" />
                            <TextBlock Text="Загрузка ресурспаков с Modrinth…"
                                       FontSize="12"
                                       Foreground="#888888"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <ScrollViewer x:Name="ResourcePacksScroll"
                                      Classes="VersionScroll"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding !IsLoadingResourcePacks}">
                            <StackPanel Margin="0,0,4,20">
                                <ItemsControl ItemsSource="{Binding VisibleResourcePackCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModCardViewModel">
                                            <Border Classes="ModCard">
                                                <Grid>
                                                    <Button Classes="ModCardButton"
                                                            Command="{Binding OpenOnModrinthCommand}"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            ToolTip.Tip="Открыть на Modrinth">
                                                        <StackPanel Spacing="8" Margin="0,0,28,0">
                                                            <Grid ColumnDefinitions="48,*">
                                                                <Border Width="48"
                                                                        Height="48"
                                                                        CornerRadius="8"
                                                                        Background="#1A1A1A"
                                                                        ClipToBounds="True"
                                                                        VerticalAlignment="Top">
                                                                    <Panel>
                                                                        <TextBlock Text="{Binding TypeGlyph}"
                                                                                   FontSize="18"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#555555"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   IsVisible="{Binding !HasIcon}" />
                                                                        <Image Source="{Binding Icon}"
                                                                               Width="48"
                                                                               Height="48"
                                                                               Stretch="UniformToFill"
                                                                               IsVisible="{Binding HasIcon}" />
                                                                    </Panel>
                                                                </Border>
                                                                <StackPanel Grid.Column="1"
                                                                            Margin="10,0,0,0"
                                                                            Spacing="2">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#E8E8E8"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="1" />
                                                                    <TextBlock Text="{Binding Author}"
                                                                               FontSize="11"
                                                                               Foreground="#888888"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock Text="{Binding DownloadsLabel}"
                                                                                   FontSize="10"
                                                                                   Foreground="#E67E22"
                                                                                   VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding GameVersionHint}"
                                                                                   FontSize="10"
                                                                                   Foreground="#666666"
                                                                                   VerticalAlignment="Center"
                                                                                   IsVisible="{Binding GameVersionHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Grid>
                                                            <TextBlock Text="{Binding DescriptionRu}"
                                                                       Opacity="{Binding DescriptionOpacity}"
                                                                       FontSize="11"
                                                                       LineHeight="16"
                                                                       Foreground="#A8A8A8"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="3"
                                                                       MinHeight="48">
                                                                <TextBlock.Transitions>
                                                                    <Transitions>
                                                                        <DoubleTransition Property="Opacity"
                                                                                          Duration="0:0:0.16"
                                                                                          Easing="CubicEaseOut" />
                                                                    </Transitions>
                                                                </TextBlock.Transitions>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding CategoriesText}"
                                                                       FontSize="10"
                                                                       Foreground="#555555"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       IsVisible="{Binding CategoriesText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                            <TextBlock Text="{Binding InstallStatus}"
                                                                       FontSize="10"
                                                                       Foreground="#E67E22"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       IsVisible="{Binding InstallStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                        </StackPanel>
                                                    </Button>

                                                    <Button Classes="ModInstallBtn"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="0,-2,-2,0"
                                                            ZIndex="2"
                                                            Content="{Binding InstallIconGlyph}"
                                                            Command="{Binding InstallModCommand}"
                                                            IsEnabled="{Binding CanInstall}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Classes="ContentTab"
                                        Content="Ещё ресурспаки"
                                        HorizontalAlignment="Center"
                                        Margin="0,12,0,8"
                                        Command="{Binding LoadMoreResourcePacksCommand}"
                                        IsVisible="{Binding CanLoadMoreResourcePacks}"
                                        IsEnabled="{Binding !IsLoadingMoreResourcePacks}"
                                        ToolTip.Tip="Загрузить следующую страницу с Modrinth" />

                                <StackPanel Spacing="6"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,4"
                                            IsVisible="{Binding IsLoadingMoreResourcePacks}">
                                    <ProgressBar IsIndeterminate="True"
                                                 Width="120"
                                                 Height="2"
                                                 Foreground="#E67E22"
                                                 Background="#333333" />
                                    <TextBlock Text="Загрузка…"
                                               FontSize="11"
                                               Foreground="#777777"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        </DockPanel>
                    </Grid>

                    <!-- ── Вкладка «Шейдеры» (Modrinth shader) ── -->
                    <Grid x:Name="TabShaders"
                          Classes="TabPage"
                          Opacity="0"
                          IsHitTestVisible="False"
                          ClipToBounds="True"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <Grid.RenderTransform>
                            <TranslateTransform Y="12" />
                        </Grid.RenderTransform>

                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <ImageBrush Source="avares://ZLauncher/Assets/shaders-bg.jpg"
                                            Stretch="UniformToFill"
                                            AlignmentX="Center"
                                            AlignmentY="Center" />
                            </Border.Background>
                        </Border>
                        <Border Background="#66222222" IsHitTestVisible="False" />
                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <RadialGradientBrush Center="50%,45%"
                                                     GradientOrigin="50%,45%"
                                                     RadiusX="1.05"
                                                     RadiusY="1.0">
                                    <GradientStop Offset="0" Color="#00000000" />
                                    <GradientStop Offset="0.65" Color="#22000000" />
                                    <GradientStop Offset="1" Color="#AA121212" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>

                        <DockPanel Margin="20,56,16,16">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,8,10">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0">
                                <CheckBox IsChecked="{Binding ShFilterBySelectedVersion}"
                                          Content="Только для выбранной версии"
                                          FontSize="11"
                                          Foreground="#DDDDDD"
                                          VerticalAlignment="Center"
                                          ToolTip.Tip="Фильтр по версии Minecraft из списка слева" />
                                <Button Classes="ContentTab"
                                        Content="НАЙТИ"
                                        Command="{Binding SearchShadersCommand}"
                                        MinWidth="72"
                                        ToolTip.Tip="Искать шейдеры на Modrinth" />
                            </StackPanel>
                            <TextBox Classes="ModsSearch"
                                     Text="{Binding ShSearchQuery}"
                                     PlaceholderText="Поиск шейдеров…"
                                     VerticalAlignment="Center">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding SearchShadersCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                        </DockPanel>

                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    Margin="0,0,8,10">
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsShFilterAll}"
                                    Content="ВСЕ"
                                    Command="{Binding SetShInstallFilterCommand}"
                                    CommandParameter="all"
                                    MinWidth="64" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsShFilterInstalled}"
                                    Content="УСТАНОВЛЕННЫЕ"
                                    Command="{Binding SetShInstallFilterCommand}"
                                    CommandParameter="installed"
                                    MinWidth="110"
                                    ToolTip.Tip="Только из папки shaderpacks" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsShFilterNotInstalled}"
                                    Content="НЕ УСТАНОВЛЕННЫЕ"
                                    Command="{Binding SetShInstallFilterCommand}"
                                    CommandParameter="not_installed"
                                    MinWidth="130" />
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding ShStatusText}"
                                   FontSize="11"
                                   Foreground="#777777"
                                   Margin="2,0,8,8"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding ShError}"
                                   IsVisible="{Binding ShError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontSize="12"
                                   Foreground="#E67E22"
                                   TextWrapping="Wrap"
                                   Margin="2,0,8,8" />

                        <StackPanel DockPanel.Dock="Top"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    Margin="0,40,0,0"
                                    IsVisible="{Binding IsLoadingShaders}">
                            <ProgressBar IsIndeterminate="True"
                                         Width="160"
                                         Height="3"
                                         Foreground="#E67E22"
                                         Background="#333333" />
                            <TextBlock Text="Загрузка шейдеров с Modrinth…"
                                       FontSize="12"
                                       Foreground="#888888"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <ScrollViewer x:Name="ShadersScroll"
                                      Classes="VersionScroll"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding !IsLoadingShaders}">
                            <StackPanel Margin="0,0,4,20">
                                <ItemsControl ItemsSource="{Binding VisibleShaderCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModCardViewModel">
                                            <Border Classes="ModCard">
                                                <Grid>
                                                    <Button Classes="ModCardButton"
                                                            Command="{Binding OpenOnModrinthCommand}"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            ToolTip.Tip="Открыть на Modrinth">
                                                        <StackPanel Spacing="8" Margin="0,0,28,0">
                                                            <Grid ColumnDefinitions="48,*">
                                                                <Border Width="48"
                                                                        Height="48"
                                                                        CornerRadius="8"
                                                                        Background="#1A1A1A"
                                                                        ClipToBounds="True"
                                                                        VerticalAlignment="Top">
                                                                    <Panel>
                                                                        <TextBlock Text="{Binding TypeGlyph}"
                                                                                   FontSize="18"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#555555"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   IsVisible="{Binding !HasIcon}" />
                                                                        <Image Source="{Binding Icon}"
                                                                               Width="48"
                                                                               Height="48"
                                                                               Stretch="UniformToFill"
                                                                               IsVisible="{Binding HasIcon}" />
                                                                    </Panel>
                                                                </Border>
                                                                <StackPanel Grid.Column="1"
                                                                            Margin="10,0,0,0"
                                                                            Spacing="2">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#E8E8E8"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="1" />
                                                                    <TextBlock Text="{Binding Author}"
                                                                               FontSize="11"
                                                                               Foreground="#888888"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock Text="{Binding DownloadsLabel}"
                                                                                   FontSize="10"
                                                                                   Foreground="#E67E22"
                                                                                   VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding GameVersionHint}"
                                                                                   FontSize="10"
                                                                                   Foreground="#666666"
                                                                                   VerticalAlignment="Center"
                                                                                   IsVisible="{Binding GameVersionHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Grid>
                                                            <TextBlock Text="{Binding DescriptionRu}"
                                                                       Opacity="{Binding DescriptionOpacity}"
                                                                       FontSize="11"
                                                                       LineHeight="16"
                                                                       Foreground="#A8A8A8"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="3"
                                                                       MinHeight="48">
                                                                <TextBlock.Transitions>
                                                                    <Transitions>
                                                                        <DoubleTransition Property="Opacity"
                                                                                          Duration="0:0:0.16"
                                                                                          Easing="CubicEaseOut" />
                                                                    </Transitions>
                                                                </TextBlock.Transitions>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding CategoriesText}"
                                                                       FontSize="10"
                                                                       Foreground="#555555"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       IsVisible="{Binding CategoriesText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                            <TextBlock Text="{Binding InstallStatus}"
                                                                       FontSize="10"
                                                                       Foreground="#E67E22"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       IsVisible="{Binding InstallStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                        </StackPanel>
                                                    </Button>

                                                    <Button Classes="ModInstallBtn"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="0,-2,-2,0"
                                                            ZIndex="2"
                                                            Content="{Binding InstallIconGlyph}"
                                                            Command="{Binding InstallModCommand}"
                                                            IsEnabled="{Binding CanInstall}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Classes="ContentTab"
                                        Content="Ещё шейдеры"
                                        HorizontalAlignment="Center"
                                        Margin="0,12,0,8"
                                        Command="{Binding LoadMoreShadersCommand}"
                                        IsVisible="{Binding CanLoadMoreShaders}"
                                        IsEnabled="{Binding !IsLoadingMoreShaders}"
                                        ToolTip.Tip="Загрузить следующую страницу с Modrinth" />

                                <StackPanel Spacing="6"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,4"
                                            IsVisible="{Binding IsLoadingMoreShaders}">
                                    <ProgressBar IsIndeterminate="True"
                                                 Width="120"
                                                 Height="2"
                                                 Foreground="#E67E22"
                                                 Background="#333333" />
                                    <TextBlock Text="Загрузка…"
                                               FontSize="11"
                                               Foreground="#777777"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        </DockPanel>
                    </Grid>

                    <!-- ── Вкладка «Ошибки» ── -->
                    <Border x:Name="TabErrors"
                            Classes="TabPage"
                            Opacity="0"
                            IsHitTestVisible="False"
                            Margin="28,56,28,24"
                            Background="#1F1F1F"
                            BorderBrush="#2E2E2E"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,16"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Border.RenderTransform>
                            <TranslateTransform Y="12" />
                        </Border.RenderTransform>
                        <DockPanel>
                            <Grid DockPanel.Dock="Top"
                                  ColumnDefinitions="*,Auto,Auto"
                                  Margin="0,0,0,12">
                                <TextBlock Text="ЖУРНАЛ ОШИБОК"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#888888"
                                           LetterSpacing="1"
                                           VerticalAlignment="Center" />
                                <Border Grid.Column="1"
                                        Background="#3A2410"
                                        CornerRadius="4"
                                        Padding="8,3"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding HasErrorMessage}">
                                    <TextBlock Text="есть ошибки"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#E67E22" />
                                </Border>
                                <Button Grid.Column="2"
                                        Classes="ContentTab"
                                        Content="{Binding CopyErrorButtonText}"
                                        Command="{Binding CopyErrorLogCommand}"
                                        ToolTip.Tip="Скопировать текст ошибки в буфер обмена"
                                        MinWidth="100"
                                        VerticalAlignment="Center" />
                            </Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <Panel>
                                    <TextBlock Text="{Binding ErrorsPanelText}"
                                               FontSize="13"
                                               LineHeight="20"
                                               TextWrapping="Wrap"
                                               Foreground="#E8A060"
                                               IsVisible="{Binding HasErrorMessage}" />
                                    <TextBlock Text="{Binding ErrorsPanelText}"
                                               FontSize="13"
                                               LineHeight="20"
                                               TextWrapping="Wrap"
                                               Foreground="#777777"
                                               IsVisible="{Binding !HasErrorMessage}" />
                                </Panel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Панель ников — вкладка «Главная» -->
                    <Border x:Name="NickPanel"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="28,0,0,24"
                            Background="#1F1F1F"
                            BorderBrush="#2E2E2E"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,12"
                            MinWidth="300"
                            Width="300"
                            ClipToBounds="True"
                            Opacity="0"
                            IsHitTestVisible="True">
                        <Border.RenderTransform>
                            <TranslateTransform Y="18">
                                <TranslateTransform.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Y"
                                                          Duration="0:0:0.35"
                                                          Easing="CubicEaseOut" />
                                    </Transitions>
                                </TranslateTransform.Transitions>
                            </TranslateTransform>
                        </Border.RenderTransform>
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity"
                                                  Duration="0:0:0.32"
                                                  Easing="CubicEaseOut" />
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                            </Transitions>
                        </Border.Transitions>
                        <Panel>
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,2">
                                    <!-- Превью скина -->
                                    <!-- Лицо скина (голова), не вся текстура -->
                                    <Border Width="48"
                                            Height="48"
                                            CornerRadius="8"
                                            ClipToBounds="True"
                                            Background="#1A1A1A"
                                            BorderBrush="#3A3A3A"
                                            BorderThickness="1"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <Panel>
                                            <TextBlock Text="?"
                                                       FontSize="18"
                                                       Foreground="#555555"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding !HasSkinPreview}" />
                                            <Image Source="{Binding SelectedSkinBitmap}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapInterpolationMode="None"
                                                   IsVisible="{Binding HasSkinPreview}" />
                                        </Panel>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="АККАУНТ"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#777777"
                                                   LetterSpacing="1" />
                                        <TextBlock Text="{Binding SelectedNickname}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E8E8E8"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SelectedAccountHint}"
                                                   FontSize="10"
                                                   Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                                <!-- Селект + dropdown (отдельные блоки с зазором) | удаление -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                                    <StackPanel Spacing="6" HorizontalAlignment="Stretch">
                                        <Button x:Name="NickSelectButton"
                                                Classes="NickSelect"
                                                Command="{Binding ToggleNickListCommand}"
                                                ToolTip.Tip="Выбрать аккаунт"
                                                ClipToBounds="True">
                                            <Grid ColumnDefinitions="*,Auto,Auto"
                                                  MinWidth="0"
                                                  ClipToBounds="True"
                                                  HorizontalAlignment="Stretch">
                                                <Border MinWidth="0"
                                                        ClipToBounds="True"
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SelectedNickname}"
                                                               Classes="NickClipText"
                                                               FontSize="13"
                                                               Foreground="#E8E8E8"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Stretch"
                                                               TextAlignment="Left"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               MaxLines="1"
                                                               MinWidth="0"
                                                               ClipToBounds="True">
                                                        <TextBlock.OpacityMask>
                                                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                                                <GradientStop Offset="0" Color="White" />
                                                                <GradientStop Offset="0.90" Color="White" />
                                                                <GradientStop Offset="1" Color="Transparent" />
                                                            </LinearGradientBrush>
                                                        </TextBlock.OpacityMask>
                                                    </TextBlock>
                                                </Border>
                                                <Border Grid.Column="1"
                                                        Classes="TagBadge"
                                                        Background="#333333"
                                                        VerticalAlignment="Center"
                                                        ZIndex="1">
                                                    <TextBlock Text="{Binding SelectedAccountTypeLabel}"
                                                               FontSize="10"
                                                               Foreground="#E67E22"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Border>
                                                <TextBlock Grid.Column="2"
                                                           Text="▾"
                                                           FontSize="11"
                                                           Foreground="#888888"
                                                           Width="18"
                                                           Margin="4,0,0,0"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           RenderTransformOrigin="50%,50%">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="{Binding NickChevronAngle}">
                                                            <RotateTransform.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="Angle"
                                                                                      Duration="0:0:0.22"
                                                                                      Easing="CubicEaseOut" />
                                                                </Transitions>
                                                            </RotateTransform.Transitions>
                                                        </RotateTransform>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Grid>
                                        </Button>

                                        <!-- Отдельная панель списка (не склеена с селектом) -->
                                        <Border x:Name="NickDropdown"
                                                Background="#252525"
                                                BorderBrush="#3A3A3A"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                ClipToBounds="True"
                                                MaxHeight="{Binding NickListExpandedHeight}"
                                                Opacity="{Binding NickListOpacity}"
                                                Margin="0"
                                                Padding="0"
                                                HorizontalAlignment="Stretch"
                                                IsHitTestVisible="{Binding IsNickListOpen}">
                                            <Border.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="MaxHeight"
                                                                      Duration="0:0:0.28"
                                                                      Easing="CubicEaseOut" />
                                                    <DoubleTransition Property="Opacity"
                                                                      Duration="0:0:0.22"
                                                                      Easing="CubicEaseOut" />
                                                </Transitions>
                                            </Border.Transitions>

                                            <ScrollViewer x:Name="NickScroll"
                                                          Classes="NickScroll"
                                                          MaxHeight="{Binding NickListMaxHeight}"
                                                          Padding="4,4,4,0"
                                                          Margin="0"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Auto">
                                                <!-- Как у версий: StackPanel + spacer = реальный Extent -->
                                                <StackPanel>
                                                <ItemsControl x:Name="NickItemsControl"
                                                              Classes="NickList"
                                                              ItemsSource="{Binding Accounts}"
                                                              HorizontalAlignment="Stretch"
                                                              Padding="0"
                                                              Margin="0">
                                                    <ItemsControl.Styles>
                                                        <Style Selector="ContentPresenter">
                                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                            <Setter Property="Margin" Value="0" />
                                                            <Setter Property="Padding" Value="0" />
                                                        </Style>
                                                        <!-- Без Background — иначе убивает :pointerover -->
                                                        <Style Selector="Button.NickListItem">
                                                            <Setter Property="Margin" Value="0,1" />
                                                            <Setter Property="Padding" Value="10,8" />
                                                            <Setter Property="BorderThickness" Value="0" />
                                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        </Style>
                                                        <Style Selector="Button.NickListItem:pointerover /template/ Border#ItemRoot">
                                                            <Setter Property="Background" Value="#333333" />
                                                        </Style>
                                                        <Style Selector="Button.NickListItem:pressed /template/ Border#ItemRoot">
                                                            <Setter Property="Background" Value="#3A2E22" />
                                                        </Style>
                                                        <Style Selector="Button.NickListItem:pointerover TextBlock.NickClipText">
                                                            <Setter Property="Foreground" Value="#E67E22" />
                                                        </Style>
                                                        <Style Selector="Button.NickListItem:pressed TextBlock.NickClipText">
                                                            <Setter Property="Foreground" Value="#E67E22" />
                                                        </Style>
                                                    </ItemsControl.Styles>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Vertical"
                                                                        HorizontalAlignment="Stretch"
                                                                        Spacing="0" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:PlayerAccount">
                                                            <Button Classes="NickListItem"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    ClipToBounds="False"
                                                                    Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SelectAccountCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <Grid ColumnDefinitions="*,Auto"
                                                                      MinWidth="0"
                                                                      ClipToBounds="False"
                                                                      HorizontalAlignment="Stretch">
                                                                    <TextBlock Text="{Binding Username}"
                                                                               Classes="NickClipText"
                                                                               FontSize="13"
                                                                               Foreground="#E8E8E8"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Stretch"
                                                                               TextAlignment="Left"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               TextWrapping="NoWrap"
                                                                               MaxLines="1"
                                                                               MinWidth="0"
                                                                               Margin="0,0,8,0" />
                                                                    <Border Grid.Column="1"
                                                                            Classes="TagBadge"
                                                                            Background="#2A2A2A"
                                                                            VerticalAlignment="Center"
                                                                            ZIndex="1">
                                                                        <TextBlock Text="{Binding TypeLabel}"
                                                                                   FontSize="10"
                                                                                   Foreground="#E67E22"
                                                                                   FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center"
                                                                                   TextAlignment="Center" />
                                                                    </Border>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- Воздух под последним аккаунтом -->
                                                <Border Height="36"
                                                        Background="Transparent"
                                                        IsHitTestVisible="False" />
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Classes="NickButton"
                                            Content="×"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Top"
                                            ToolTip.Tip="Удалить аккаунт"
                                            Command="{Binding RemoveAccountCommand}"
                                            CommandParameter="{Binding SelectedAccount}" />
                                </Grid>

								<!-- Создание обычного аккаунта -->
                                <TextBlock Text="СОЗДАТЬ ОБЫЧНЫЙ АККАУНТ"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#666666"
                                           LetterSpacing="0.5"
                                           Margin="0,4,0,0" />
                                <Grid x:Name="NickInputRow" ColumnDefinitions="*,Auto">
                                    <TextBox x:Name="NickInputBox"
                                             Classes="NickInput"
                                             PlaceholderText="Имя игрока (3–16)"
                                             Text="{Binding NewNicknameText}"
                                             MaxLength="16"
                                             KeyDown="OnNickInputKeyDown"
                                             ToolTip.Tip="Без входа в Microsoft — только ник (обычный аккаунт)" />
                                    <Button Grid.Column="1"
                                            x:Name="AddNickButton"
                                            Classes="NickButton"
                                            Content="+"
                                            Margin="8,0,0,0"
                                            ToolTip.Tip="Создать обычный аккаунт"
                                            Click="OnAddNicknameClick" />
                                </Grid>
                            </StackPanel>

                            <!-- Летающий ник (анимация добавления) -->
                            <TextBlock x:Name="FlyingNick"
                                       IsHitTestVisible="False"
                                       IsVisible="False"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#E67E22"
                                       Opacity="0"
                                       ZIndex="30">
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                        <TranslateTransform />
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Panel>
                    </Border>

                    <!-- Шестерёнка настроек запуска + кнопка ИГРАТЬ — вкладка «Версии» -->
                    <StackPanel x:Name="PlayBar"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,28,24"
                                Spacing="10"
                                Opacity="0"
                                IsHitTestVisible="True">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="18">
                                <TranslateTransform.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Y"
                                                          Duration="0:0:0.35"
                                                          Easing="CubicEaseOut" />
                                    </Transitions>
                                </TranslateTransform.Transitions>
                            </TranslateTransform>
                        </StackPanel.RenderTransform>
                        <StackPanel.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity"
                                                  Duration="0:0:0.32"
                                                  Easing="CubicEaseOut" />
                            </Transitions>
                        </StackPanel.Transitions>

                        <Button x:Name="OpenGameFolderButton"
                                Classes="LaunchFolder"
                                ToolTip.Tip="Открыть папку игры"
                                VerticalAlignment="Bottom"
                                Command="{Binding OpenGameFolderCommand}" />

                        <Button x:Name="LaunchSettingsButton"
                                Classes="LaunchGear"
                                ToolTip.Tip="Настройки запуска"
                                VerticalAlignment="Bottom"
                                Click="OnLaunchSettingsClick" />

                        <Popup x:Name="LaunchSettingsPopup"
                               Placement="TopEdgeAlignedRight"
                               PlacementTarget="{Binding #LaunchSettingsButton}"
                               IsLightDismissEnabled="True"
                               OverlayDismissEventPassThrough="False"
                               Closed="OnLaunchSettingsPopupClosed">
                            <!-- Без BoxShadow: с Opacity/Scale он даёт «грязный» прямоугольник -->
                            <Border x:Name="LaunchSettingsPanel"
                                    Width="300"
                                    Margin="0,0,0,8"
                                    Background="#2A2A2A"
                                    BorderBrush="#454545"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14"
                                    Opacity="0"
                                    RenderTransformOrigin="100%,100%">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94">
                                            <ScaleTransform.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="ScaleX"
                                                                      Duration="0:0:0.24"
                                                                      Easing="CubicEaseOut" />
                                                    <DoubleTransition Property="ScaleY"
                                                                      Duration="0:0:0.24"
                                                                      Easing="CubicEaseOut" />
                                                </Transitions>
                                            </ScaleTransform.Transitions>
                                        </ScaleTransform>
                                        <TranslateTransform Y="10">
                                            <TranslateTransform.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Y"
                                                                      Duration="0:0:0.24"
                                                                      Easing="CubicEaseOut" />
                                                </Transitions>
                                            </TranslateTransform.Transitions>
                                        </TranslateTransform>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity"
                                                          Duration="0:0:0.22"
                                                          Easing="CubicEaseOut" />
                                    </Transitions>
                                </Border.Transitions>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="Запуск игры"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#E0E0E0" />

                                    <!-- RAM -->
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Оперативная память"
                                                       FontSize="12"
                                                       Foreground="#AAAAAA"
                                                       VerticalAlignment="Center" />
                                            <!-- Цифры ГБ — та же побуквенная анимация, что у ИГРАТЬ -->
                                            <Panel Grid.Column="1"
                                                   x:Name="MemoryLabelHost"
                                                   Height="18"
                                                   MinWidth="72"
                                                   ClipToBounds="True"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   IsHitTestVisible="False">
                                                <StackPanel x:Name="MemoryLabelOut"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            IsHitTestVisible="False" />
                                                <StackPanel x:Name="MemoryLabelIn"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            IsHitTestVisible="False" />
                                            </Panel>
                                        </Grid>
                                        <Slider x:Name="MemorySlider"
                                                Classes="SmoothMemory"
                                                Minimum="1024"
                                                Maximum="{Binding MemorySliderMax}"
                                                TickFrequency="512"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding MemoryMaxMb, Mode=TwoWay}"
                                                IsEnabled="{Binding IsMemorySliderEnabled}"
                                                PointerReleased="OnMemorySliderPointerReleased"
                                                LostFocus="OnMemorySliderLostFocus" />
                                        <CheckBox Classes="FilterCheck"
                                                  Content="Автоматический выбор памяти"
                                                  IsChecked="{Binding AutoMemory}"
                                                  ToolTip.Tip="Подбирает объём RAM под ваш ПК (~половина ОЗУ, с запасом для системы)."
                                                  Margin="0" />
                                    </StackPanel>

                                    <!-- Разрешение -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Окно"
                                                   FontSize="12"
                                                   Foreground="#AAAAAA" />
                                        <Grid ColumnDefinitions="*,Auto,*" >
                                            <NumericUpDown Minimum="640"
                                                           Maximum="7680"
                                                           Increment="10"
                                                           Value="{Binding WindowWidth}"
                                                           FormatString="0"
                                                           ShowButtonSpinner="False" />
                                            <TextBlock Grid.Column="1"
                                                       Text="×"
                                                       Margin="8,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="#666666" />
                                            <NumericUpDown Grid.Column="2"
                                                           Minimum="480"
                                                           Maximum="4320"
                                                           Increment="10"
                                                           Value="{Binding WindowHeight}"
                                                           FormatString="0"
                                                           ShowButtonSpinner="False" />
                                        </Grid>
                                        <CheckBox Classes="FilterCheck"
                                                  Content="На весь экран (окно, без смены режима)"
                                                  IsChecked="{Binding Fullscreen}"
                                                  ToolTip.Tip="Окно размером с монитор. Exclusive fullscreen отключён — не мигает и не ломает картинку."
                                                  Margin="0" />
                                    </StackPanel>

                                    <!-- JVM args -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Аргументы JVM"
                                                   FontSize="12"
                                                   Foreground="#AAAAAA" />
                                        <TextBox Classes="NickInput"
                                                 Text="{Binding JvmArguments}"
                                                 PlaceholderText="-XX:+UseG1GC …"
                                                 AcceptsReturn="False" />
                                    </StackPanel>

                                    <!-- Поведение лаунчера после старта -->
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="После запуска"
                                                   FontSize="12"
                                                   Foreground="#AAAAAA"
                                                   Margin="0,2,0,2" />
                                        <CheckBox Classes="FilterCheck"
                                                  Content="Запускать игру после установки"
                                                  IsChecked="{Binding LaunchAfterInstall}"
                                                  ToolTip.Tip="После успешной установки сразу запустить игру."
                                                  Margin="0" />
                                        <CheckBox Classes="FilterCheck"
                                                  Content="Сворачивать лаунчер после запуска игры"
                                                  IsChecked="{Binding MinimizeOnLaunch}"
                                                  Margin="0" />
                                        <CheckBox Classes="FilterCheck"
                                                  Content="Закрывать лаунчер после запуска игры"
                                                  IsChecked="{Binding CloseOnLaunch}"
                                                  ToolTip.Tip="Имеет приоритет над сворачиванием."
                                                  Margin="0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Button Classes="PlayButton"
                                Command="{Binding PrimaryActionCommand}"
                                IsEnabled="{Binding IsPrimaryActionEnabled}"
                                Focusable="False"
                                ToolTip.Tip="{Binding PrimaryActionTip}">
                            <Border Width="180"
                                    Height="48"
                                    CornerRadius="8"
                                    ClipToBounds="True"
                                    Background="#3A2410">
                                <Panel>
                                    <!-- Заливка: прогресс установки / полный фон; при ЗАПУЩЕНА — серый через disabled -->
                                    <Border HorizontalAlignment="Left"
                                            Height="48"
                                            Background="#E67E22"
                                            Width="{Binding InstallFillWidth}">
                                        <Border.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Width"
                                                                  Duration="0:0:0.22"
                                                                  Easing="CubicEaseOut" />
                                            </Transitions>
                                        </Border.Transitions>
                                    </Border>
                                    <!-- Буквы кнопки: улетают вверх / прилетают снизу -->
                                    <Panel x:Name="PlayLabelHost"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           ZIndex="1"
                                           ClipToBounds="True"
                                           Height="28"
                                           MinWidth="100"
                                           IsHitTestVisible="False">
                                        <StackPanel x:Name="PlayLabelOut"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    IsHitTestVisible="False" />
                                        <StackPanel x:Name="PlayLabelIn"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    IsHitTestVisible="False" />
                                    </Panel>
                                </Panel>
                            </Border>
                        </Button>
                    </StackPanel>

                    </Panel>

                    <!-- Табы поверх фона — не режут картинку по высоте -->
                    <Border VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            ZIndex="40"
                            Padding="20,12,20,12"
                            IsHitTestVisible="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                                <GradientStop Offset="0" Color="#F01A1A1A" />
                                <GradientStop Offset="0.55" Color="#C01A1A1A" />
                                <GradientStop Offset="1" Color="#001A1A1A" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsHomeTab}"
                                    Content="ГЛАВНАЯ"
                                    Command="{Binding SelectHomeTabCommand}"
                                    ToolTip.Tip="Аккаунт, версия и запуск" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsVersionsTab}"
                                    Content="ВЕРСИИ"
                                    Command="{Binding SelectVersionsTabCommand}"
                                    ToolTip.Tip="Подверсии (Vanilla / Forge / OptiFine…) выбранной версии" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsModsTab}"
                                    Content="МОДИФИКАЦИИ"
                                    Command="{Binding SelectModsTabCommand}"
                                    ToolTip.Tip="Моды с Modrinth" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsResourcePacksTab}"
                                    Content="РЕСУРСПАКИ"
                                    Command="{Binding SelectResourcePacksTabCommand}"
                                    ToolTip.Tip="Ресурспаки с Modrinth" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsShadersTab}"
                                    Content="ШЕЙДЕРЫ"
                                    Command="{Binding SelectShadersTabCommand}"
                                    ToolTip.Tip="Шейдеры с Modrinth" />
                            <Button Classes="ContentTab"
                                    Classes.active="{Binding IsErrorsTab}"
                                    Content="ОШИБКИ"
                                    Command="{Binding SelectErrorsTabCommand}"
                                    ToolTip.Tip="Ошибки установки и запуска" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
    </Border>

</Window>
